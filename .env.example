# ─── DigitalOcean Gradient AI ────────────────────────────────────────────────
# DO Gradient AI serverless inference (OpenAI-compatible)
GRADIENT_ENDPOINT_URL=https://api.digitalocean.com/v2/gen-ai

# Your DigitalOcean Personal Access Token (generate at cloud.digitalocean.com/account/api)
GRADIENT_API_KEY=your_do_api_key_here

# Model ID to use — run: python services/list_models.py to see all available
GRADIENT_MODEL=deepseek-ai/DeepSeek-R1

# ─── ChromaDB ────────────────────────────────────────────────────────────────
# Directory where ChromaDB persists vector data
CHROMA_PERSIST_DIR=./data/chroma_db

# ─── Repo Cloning ────────────────────────────────────────────────────────────
# Temp directory for cloned repos (cleaned up after indexing)
REPOS_TMP_DIR=/tmp/autodoc_repos

# ─── DigitalOcean Spaces (for model artifacts + datasets) ────────────────────
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=autodoc-ai-artifacts

# ─── Redis Cache ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI Microservice API ─────────────────────────────────────────────────────
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
